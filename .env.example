# Global
SECURITY_MODE=dev # dev or prod
ALLOW_ORIGINS=*

# Gateway Security
GATEWAY_JWT_SECRET=replace_me_with_long_random_string
GATEWAY_VALIDATE_AUD=false
GATEWAY_SYSTEM_TOKEN=system_01
JWT_ISSUER=gco-engine
JWT_AUDIENCE=gco-services
JWT_ALGORITHM=HS256 # Or RS256 if using JWKS
GATEWAY_JWKS_URL=
JWKS_CACHE_TTL=3600

# Databases
GOVERNANCE_DB_URL=postgresql://gco_admin:gco_secret@db:5432/gco_engine
KPI_DB_URL=postgresql://gco_admin:gco_secret@db:5432/gco_engine
POLICY_DB_URL=postgresql://gco_admin:gco_secret@db:5432/gco_engine
OT_DB_URL=postgresql://gco_admin:gco_secret@db:5432/gco_engine
STORAGE_BACKEND=database # database or file

# OT Commissioning
COMMISSIONING_MODE=false
FEATURE_SIMULATED_OPCUA=true
FEATURE_GUARDED=false
MIN_WRITE_INTERVAL_SEC=10
READBACK_TOLERANCE_TEMPERATURE=0.2
READBACK_TOLERANCE_FLOW=0.1

# LLM
LLM_API_KEY=unset
PROVIDER=gemini
MODEL_ID=gemini-1.5-pro

# Services
GOVERNANCE_BASE=http://governance:8001
OPTIMIZER_BASE=http://optimizer:8002
OPA_BASE=http://opa:8181
LLM_BASE=http://llm:8004
KPI_BASE=http://kpi:8005
POLICY_BASE=http://policy:8006
TWIN_BASE=http://twin:8007
EVIDENCE_BASE=http://evidence:8008
OT_BASE=http://ot:8009
